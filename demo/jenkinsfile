pipeline {
    agent any

    tools {
        maven 'maven'
    }

    stages {

        stage('Clone Code') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
    steps {
        dir('demo') {
            bat 'mvn clean package'
        }
    }
}

        stage('Docker Build') {
    steps {
        dir('demo') {
            bat 'docker build -t my-app .'
        }
    }
}

        stage('Deploy') {
    steps {
        dir('demo') {
            bat '''
            docker stop my-app || exit 0
            docker rm my-app || exit 0
            docker run -d -p 8082:8080 --name my-app my-app
            '''
        }
      }
    }
  }
}
